spring.application.name=api

# --- Database (Neon PostgreSQL) ---
# Pooled connection string (from Neon dashboard → Connection Details → Pooled)
spring.datasource.url=jdbc:postgresql://<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channelBinding=require
spring.datasource.username=<neon-username>
spring.datasource.password=<neon-password>
spring.datasource.driver-class-name=org.postgresql.Driver

# --- Flyway ---
# Unpooled connection string (from Neon dashboard → Connection Details → Direct)
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.url=jdbc:postgresql://<host>.<region>.aws.neon.tech/<dbname>?sslmode=require&channelBinding=require
spring.flyway.user=<neon-username>
spring.flyway.password=<neon-password>

# --- JPA / Hibernate ---
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true

# --- JWT ---
jwt.secret=${JWT_SECRET:changeme-replace-with-a-256-bit-secret}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}

# --- Stripe ---
stripe.publishable-key=<your-stripe-publishable-key>
stripe.secret-key=<your-stripe-secret-key>
stripe.webhook-secret=<your-stripe-webhook-secret>

# --- Claude API ---
use.live.ai=${USE_LIVE_AI:false}
claude.api-key=<your-claude-api-key>

# --- Logging ---
logging.level.com.cupboard=DEBUG
logging.level.org.springframework.web=DEBUG
logging.level.org.hibernate.SQL=DEBUG
